{
  "name": "grimmia",
  "productName": "Grimmia",
  "version": "0.1.34",
  "description": "A friendly desktop app for the Internet Archive — search, browse, download, and upload without the command line.",
  "main": "src/main/main.js",
  "author": "Moss on Stone <moss-on-stone@protonmail.com>",
  "license": "CC0-1.0",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "test": "node --test",
    "test:watch": "node --test --watch",
    "test:coverage": "node --test --experimental-test-coverage",
    "selftest": "scripts/selftest.sh",
    "screenshot": "scripts/screenshot.sh",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "pack": "electron-builder --dir"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "org.grimmia.app",
    "productName": "Grimmia",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "!**/*.map"
    ],
    "afterPack": "build/adhoc-sign.js",
    "afterSign": "build/notarize.js",
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "artifactName": "${productName}-${version}-macOS-${arch}.${ext}",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "title": "${productName} (${arch})",
      "window": {
        "width": 540,
        "height": 400
      },
      "contents": [
        {
          "x": 130,
          "y": 180,
          "type": "file"
        },
        {
          "x": 410,
          "y": 180,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 270,
          "y": 330,
          "type": "file",
          "path": "build/README-macOS.txt",
          "name": "Read Me First.txt"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "publisherName": "Grimmia",
      "signingHashAlgorithms": [
        "sha256"
      ],
      "extraFiles": [
        {
          "from": "build/README-Windows.txt",
          "to": "Read Me First.txt"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    }
  }
}
